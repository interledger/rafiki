meta {
  name: Get Tenants (Operator)
  type: graphql
  seq: 1
}

post {
  url: {{RafikiGraphqlHost}}/graphql
  body: graphql
  auth: none
}

body:graphql {
  query GetTenants {
    tenants {
      edges {
        node {
          id
          publicName
        }
      }
    }
  }
}

script:pre-request {
  const scripts = require('./scripts');
  
  const tenantId = bru.getEnvVar('operatorTenantId');
  const secret = bru.getEnvVar('operatorSecret');
  
  console.log("Listing Tenants as Operator...");
  
  bru.setEnvVar('backendApiSignatureSecret', secret);
  bru.setEnvVar('senderTenantId', tenantId);
  
  scripts.addApiSignatureHeader();
  
  console.log("Generated Signature: " + req.getHeader('signature'));
  console.log("Tenant ID Header: " + req.getHeader('tenant-id'));
}
